# ========================================
# Writerly Production Environment Variables
# ========================================

# Database
POSTGRES_PASSWORD=your_secure_postgres_password_here

# Redis
REDIS_PASSWORD=your_secure_redis_password_here

# Slack Integration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_SIGNING_SECRET=your_slack_signing_secret_here

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here

# Security
SECRET_KEY=your_super_secret_flask_key_minimum_32_chars_long

# Monitoring
GRAFANA_PASSWORD=your_secure_grafana_password_here

# Deployment
DOMAIN_NAME=your-domain.com
EMAIL_FOR_LETSENCRYPT=your-email@domain.com

# Optional: External URLs (if using managed services)
# DATABASE_URL=postgresql://user:pass@host:port/db
# REDIS_URL=redis://user:pass@host:port/db

# SSL Certificate paths (if using custom certificates)
# SSL_CERT_FILE=/path/to/cert.pem
# SSL_KEY_FILE=/path/to/key.pem

# Log Level
LOG_LEVEL=INFO

# Performance Tuning
CELERY_WORKER_CONCURRENCY=4
WEB_WORKER_REPLICAS=3

# Backup
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30 