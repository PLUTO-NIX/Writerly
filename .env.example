# Writerly - Slack AI Message Assistant
# 환경변수 설정 예시 파일
# 이 파일을 복사하여 .env 파일을 만들고 실제 값으로 수정하세요

# Flask 설정
SECRET_KEY=your-secret-key-change-in-production
FLASK_ENV=development

# 슬랙 앱 설정 (https://api.slack.com/apps 에서 발급)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_CLIENT_ID=your-client-id-here
SLACK_CLIENT_SECRET=your-client-secret-here

# OpenAI API 설정 (https://platform.openai.com/api-keys 에서 발급)
OPENAI_API_KEY=sk-your-openai-api-key-here

# 데이터베이스 설정
# 개발 환경: SQLite (기본값)
DATABASE_URL=sqlite:///writerly.db
# 프로덕션 환경: PostgreSQL
# DATABASE_URL=postgresql://username:password@localhost:5432/writerly

# Redis 설정 (Celery 메시지 브로커)
REDIS_URL=redis://localhost:6379/0

# Celery 설정
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# 암호화 키 (사용자 토큰 암호화용)
ENCRYPTION_KEY=your-encryption-key-change-in-production

# 로깅 설정
LOG_LEVEL=INFO
LOG_FILE=app.log

# 개발용 설정
DEBUG=True

# 애플리케이션 설정
APP_NAME=Writerly
APP_VERSION=1.0.0
